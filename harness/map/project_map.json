{
  "schema_version": 1,
  "project": {
    "name": "Agent Harness Engineering",
    "purpose": "Reusable execution framework for AI coding agents",
    "stage": "stage-0"
  },
  "modules": {
    "agent_protocol": {
      "path": "AGENTS.md",
      "role": "Mandatory workflow, safety, verification, and completion contract",
      "entry_files": ["AGENTS.md", "docs/agent/execution-harness.md", "docs/agent/design-principles.md"],
      "signals": ["agent", "workflow", "protocol", "contract", "规则", "工作流", "completion", "report", "principle", "原则"],
      "depends_on": ["project_navigation", "verification", "execution_plans"]
    },
    "project_navigation": {
      "path": "docs/agent/",
      "role": "Human-readable and machine-readable repository navigation",
      "entry_files": ["docs/agent/project-map.md", "harness/map/project_map.json"],
      "signals": ["map", "module", "context", "navigation", "地图", "上下文", "定位", "discovery"],
      "depends_on": []
    },
    "context_runtime": {
      "path": "harness/runtime/",
      "role": "Select candidate context from task text and the structured map",
      "entry_files": ["harness/runtime/context_loader.dart"],
      "signals": ["context", "loader", "candidate", "signal", "上下文", "候选", "关键词", "匹配"],
      "depends_on": ["project_navigation"]
    },
    "verification": {
      "path": "harness/evaluation/",
      "role": "Configure and execute repository verification checks",
      "entry_files": ["harness/evaluation/checks.json", "harness/evaluation/eval.sh", "harness/evaluation/harness_lint.dart"],
      "signals": ["verify", "check", "test", "lint", "build", "invariant", "验证", "测试", "检查", "评估", "约束"],
      "depends_on": []
    },
    "execution_plans": {
      "path": "docs/agent/plans/",
      "role": "Preserve resumable state, decisions, milestones, and verification for complex work",
      "entry_files": ["docs/agent/plans/README.md", "docs/agent/plans/_template.md"],
      "signals": ["plan", "milestone", "decision", "migration", "resume", "计划", "里程碑", "决策", "迁移"],
      "depends_on": ["project_navigation", "verification"]
    },
    "adoption": {
      "path": "docs/agent/adoption.md",
      "role": "Define portable-core adoption, instruction layering, and customization safety",
      "entry_files": ["docs/agent/adoption.md"],
      "signals": ["adopt", "install", "copy", "override", "nested", "接入", "复制", "覆盖", "嵌套"],
      "depends_on": ["agent_protocol", "project_navigation"]
    },
    "evolution": {
      "path": "harness/evolution/",
      "role": "Store reviewed failure guidance and raw failure records",
      "entry_files": ["harness/evolution/rules.json", "harness/evolution/failure_log.jsonl"],
      "signals": ["failure", "error", "rule", "learning", "失败", "错误", "规则", "演进"],
      "depends_on": ["verification"]
    },
    "documentation_maintenance": {
      "path": "docs/agent/update-rules.md",
      "role": "Define when Agent-facing documentation changes are required",
      "entry_files": ["docs/agent/update-rules.md"],
      "signals": ["docs", "update", "drift", "documentation", "文档", "更新", "漂移", "维护"],
      "depends_on": ["project_navigation"]
    }
  }
}
