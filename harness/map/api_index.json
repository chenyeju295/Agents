{
  "_meta": {
    "note": "跨包调用时的接口速查。只索引公开 API（barrel 导出的），内部 src/ 不列在这里。"
  },

  "BleService.scanDevices": {
    "package": "core_ble",
    "barrel": "lib/core_ble.dart",
    "class": "BleService",
    "method": "scanDevices",
    "signature": "Stream<List<BleDevice>> scanDevices({List<String> serviceUuids, Duration timeout})",
    "provider": "bleServiceProvider",
    "returns": "Stream — 持续推送，调用方负责取消订阅"
  },

  "BleService.connect": {
    "package": "core_ble",
    "barrel": "lib/core_ble.dart",
    "class": "BleService",
    "method": "connect",
    "signature": "Future<Result<BleConnection>> connect(String deviceId, {Duration timeout})",
    "provider": "bleServiceProvider",
    "returns": "Result<BleConnection> — 失败时携带 BleError，不抛异常"
  },

  "bleConnectionProvider": {
    "package": "core_ble",
    "barrel": "lib/core_ble.dart",
    "type": "StreamProvider.family<BleConnectionState, String>",
    "usage": "ref.watch(bleConnectionProvider(deviceId))",
    "note": "按 deviceId 分实例缓存，多个 Widget watch 同一 deviceId 共享同一 Stream"
  },

  "PermissionService.request": {
    "package": "core_permission",
    "barrel": "lib/core_permission.dart",
    "class": "PermissionService",
    "method": "request",
    "signature": "Future<Result<void>> request(AppPermission permission)",
    "provider": "permissionServiceProvider",
    "returns": "Result<void> — 用户拒绝时返回 PermissionError.denied"
  },

  "NetworkService.get": {
    "package": "core_network",
    "barrel": "lib/core_network.dart",
    "class": "NetworkService",
    "method": "get",
    "signature": "Future<Result<T>> get<T>(String path, {Map<String, dynamic>? queryParameters, T Function(Map<String, dynamic>)? fromJson})",
    "provider": "networkServiceProvider"
  },

  "StorageService.read": {
    "package": "core_storage",
    "barrel": "lib/core_storage.dart",
    "class": "StorageService",
    "method": "read",
    "signature": "Future<Result<String?>> read(String key)",
    "provider": "storageServiceProvider"
  }
}
